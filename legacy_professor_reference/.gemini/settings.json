{
  "mcpServers": {
    "superset-mcp": {
      "command": "npx",
      "args": ["-y", "superset-mcp"],
      "env": {
        "SUPERSET_BASE_URL": "http://localhost:8088",
        "SUPERSET_USERNAME": "admin",
        "SUPERSET_PASSWORD": "admin"
      }
    },
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@brave/brave-search-mcp-server", "--transport", "stdio"],
      "env": {
        "BRAVE_API_KEY": "BSA***********"
      }
    }
  }
}
